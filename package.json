{
  "name": "mh-sample-fl",
  "version": "0.1.0",
  "private": true,
  "description": "MH Sample FL - local-first sample and project memory workspace for FL Studio producers",
  "author": "Producer Minh Hieu",
  "license": "UNLICENSED",
  "main": "src/main/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "start": "electron .",
    "build": "tsc --noEmit && vite build",
    "test": "node --test tests/*.test.cjs",
    "check": "npm run test && npm run build",
    "dist:win": "npm run check && electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "music-metadata": "11.13.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "typescript": "^5.9.3",
    "vite": "8.1.4",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.minhhieu.mhsamplefl",
    "productName": "MH Sample FL",
    "asar": true,
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/preload/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
